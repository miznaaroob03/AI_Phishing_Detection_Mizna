{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "outputDirectory": "dist/public",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-phishing-detection-1-zafv.onrender.com/api/:path*"
    },
    {
      "source": "/((?!assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
